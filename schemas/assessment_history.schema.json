{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "assessment_history.schema.json",
  "title": "Assessment History (fact_assessment_history)",
  "description": "Append-only record of every assessment version the platform has produced or approved. Its purpose is auditability: prior assessments are archived, never silently rewritten, so a later change of view is visible as a change rather than as the way things always were.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "entries"],
  "properties": {
    "version": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "history_id",
          "subject_type",
          "subject_id",
          "revision_number",
          "recorded_at",
          "action",
          "content_sha256",
          "supersedes_history_id",
          "summary"
        ],
        "properties": {
          "history_id": {"type": "string", "pattern": "^HIST-[A-Za-z0-9-]+$"},
          "subject_type": {"enum": ["lane_assessment", "event", "thailand_assessment", "review_package", "approved_assessment"]},
          "subject_id": {"type": "string", "minLength": 1},
          "revision_number": {"type": "integer", "minimum": 0},
          "recorded_at": {"type": "string", "format": "date-time"},
          "action": {"enum": ["created", "revised", "approved", "rejected", "archived", "superseded", "closed"]},
          "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "supersedes_history_id": {"type": ["string", "null"]},
          "summary": {"type": "string", "minLength": 1},
          "changed_fields": {"type": "array", "items": {"type": "string"}},
          "reviewer_record": {"type": ["string", "null"]},
          "archive_path": {"type": ["string", "null"]}
        }
      }
    }
  }
}
