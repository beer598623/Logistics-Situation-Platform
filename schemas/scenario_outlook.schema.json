{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scenario_outlook.schema.json",
  "title": "Scenario Outlook",
  "description": "A base / deterioration / improvement outlook set. Scenario completeness is a contract requirement: all three cases must be present, each with a time horizon, trigger conditions, evidence references, confidence and data gaps. Unsupported point forecasts for freight, transit time, inventory or cost are prohibited and enforced by scripts/validate.py.",
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "narrative",
        "time_horizon",
        "trigger_conditions",
        "evidence_ids",
        "confidence",
        "data_gaps"
      ],
      "properties": {
        "narrative": {"type": "string", "minLength": 1},
        "time_horizon": {"enum": ["0-7_days", "1-4_weeks", "1-3_months", "longer_term"]},
        "trigger_conditions": {
          "type": "array",
          "minItems": 1,
          "description": "Observable, monitorable conditions that would indicate this case is materialising. A scenario with no trigger is not monitorable and is rejected.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["condition", "observable_via"],
            "properties": {
              "condition": {"type": "string", "minLength": 1},
              "observable_via": {
                "type": "string",
                "minLength": 1,
                "description": "The indicator, source or notice channel through which the trigger would actually be observed."
              }
            }
          }
        },
        "evidence_ids": {"type": "array", "items": {"type": "string"}},
        "confidence": {"enum": ["low", "medium", "high"]},
        "data_gaps": {"type": "array", "items": {"type": "string"}},
        "point_forecast_disclaimer": {
          "type": ["string", "null"],
          "description": "Optional statement of why no numeric point forecast is given. Never a place to put one."
        }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["outlook_id", "subject_type", "subject_id", "generated_at", "base_case", "deterioration_case", "improvement_case", "known_limitations"],
  "properties": {
    "outlook_id": {"type": "string", "pattern": "^OUT-[A-Za-z0-9-]+$"},
    "subject_type": {"enum": ["lane", "thailand_ocean", "thailand_overall", "event", "chokepoint"]},
    "subject_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "data_cutoff_at": {"type": ["string", "null"], "format": "date-time"},
    "base_case": {"$ref": "#/$defs/case"},
    "deterioration_case": {"$ref": "#/$defs/case"},
    "improvement_case": {"$ref": "#/$defs/case"},
    "known_limitations": {"type": "array", "items": {"type": "string"}}
  }
}
