{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source_status.schema.json",
  "title": "Source Health Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["generated_at", "overall_status", "coverage_message", "sources"],
  "properties": {
    "generated_at": {"type": "string", "format": "date-time"},
    "overall_status": {"enum": ["sufficient", "limited", "insufficient"]},
    "coverage_message": {"type": "string"},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id", "status", "last_checked_at", "last_success_at", "last_error",
          "item_count", "required_for_publication", "max_stale_minutes"
        ],
        "properties": {
          "source_id": {"type": "string"},
          "status": {"enum": ["fresh", "stale", "very_stale", "no_data", "disabled", "error"]},
          "last_checked_at": {"type": ["string", "null"], "format": "date-time"},
          "last_success_at": {"type": ["string", "null"], "format": "date-time"},
          "last_error": {"type": ["string", "null"]},
          "item_count": {"type": ["integer", "null"], "minimum": 0},
          "required_for_publication": {"type": "boolean"},
          "max_stale_minutes": {"type": "integer", "minimum": 1}
        }
      }
    }
  }
}
