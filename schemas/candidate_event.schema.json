{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Candidate Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "title",
    "detected_at",
    "event_date",
    "publication_date",
    "source_url",
    "source_name",
    "source_class",
    "primary_category",
    "geography",
    "transport_modes",
    "segments",
    "headline_summary",
    "raw_claims",
    "collector_status",
    "retrieved_at",
    "canonical_event_id",
    "event_fingerprint",
    "merge_status",
    "first_seen_at",
    "last_seen_at",
    "last_changed_at",
    "supersedes",
    "content_signature",
    "identity_date_bucket"
  ],
  "properties": {
    "candidate_id": {
      "type": "string",
      "pattern": "^CAND-[0-9]{8}-[0-9]{3,}$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "detected_at": {
      "type": "string",
      "format": "date-time"
    },
    "event_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "publication_date": {
      "type": "string",
      "format": "date"
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "source_name": {
      "type": "string"
    },
    "source_class": {
      "enum": [
        "official",
        "operator",
        "international",
        "industry",
        "news",
        "vendor"
      ]
    },
    "primary_category": {
      "type": "string"
    },
    "secondary_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "geography": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "transport_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "headline_summary": {
      "type": "string"
    },
    "raw_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "duplicate_cluster_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "collector_status": {
      "enum": [
        "new",
        "duplicate",
        "updated",
        "rejected"
      ]
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_id": {
      "type": ["string", "null"],
      "pattern": "^[A-Z0-9_]+$"
    },
    "external_event_id": {
      "type": ["string", "null"]
    },
    "source_revision": {
      "type": ["string", "null"]
    },
    "canonical_event_id": {
      "type": "string",
      "pattern": "^CEVT-[0-9a-f]{16}$"
    },
    "event_fingerprint": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "merge_status": {
      "enum": [
        "unmatched",
        "matched_external_id",
        "matched_fingerprint",
        "merge_suggested",
        "merged_approved",
        "split_required"
      ]
    },
    "first_seen_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_seen_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_changed_at": {
      "type": "string",
      "format": "date-time"
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^CEVT-[0-9a-f]{16}$"
      }
    },
    "content_signature": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "identity_date_bucket": {
      "type": "string",
      "format": "date"
    }
  }
}
