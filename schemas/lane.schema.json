{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lane.schema.json",
  "title": "Lane Definition (dim_lane)",
  "description": "A Lane is the primary analytical object (scope document Section 7). A Lane is mode-tagged rather than Ocean-only: the same contract expresses an Air lane, a road corridor or a rail lane, so the Air and Land modules extend the lane set without a schema change. Every Lane must declare the resolution it actually has -- a regional Lane must never be displayed as if it were port-level.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lane_id",
    "name",
    "mode",
    "origin_scope",
    "destination_scope",
    "direction",
    "resolution",
    "country_ids",
    "node_ids",
    "chokepoint_ids",
    "selection_evidence",
    "data_period_used",
    "known_limitations",
    "review_date",
    "status"
  ],
  "properties": {
    "lane_id": {"type": "string", "pattern": "^LANE-[A-Z0-9-]+$"},
    "name": {"type": "string", "minLength": 1},
    "mode": {"$ref": "observation_common.schema.json#/$defs/transportMode"},
    "origin_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "geography_ids"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "geography_ids": {"type": "array", "items": {"type": "string", "pattern": "^GEO-[A-Z0-9-]+$"}, "minItems": 1, "uniqueItems": true}
      }
    },
    "destination_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "geography_ids"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "geography_ids": {"type": "array", "items": {"type": "string", "pattern": "^GEO-[A-Z0-9-]+$"}, "minItems": 1, "uniqueItems": true}
      }
    },
    "direction": {"enum": ["export", "import", "bidirectional", "domestic"]},
    "resolution": {
      "description": "The analytical resolution the Lane actually supports given available data. The Dashboard must state this verbatim.",
      "enum": ["port_pair", "port_group", "country", "regional", "corridor"]
    },
    "country_ids": {"type": "array", "items": {"type": "string", "pattern": "^[A-Z]{2}$"}, "minItems": 1, "uniqueItems": true},
    "node_ids": {"type": "array", "items": {"type": "string", "pattern": "^NODE-[A-Z0-9-]+$"}, "uniqueItems": true},
    "chokepoint_ids": {"type": "array", "items": {"type": "string", "pattern": "^CHK-[A-Z0-9-]+$"}, "uniqueItems": true},
    "selection_evidence": {
      "type": "array",
      "minItems": 1,
      "description": "Why this Lane was selected. Every entry must state its own evidence class, so a Lane selected on structural criteria can never be presented as if it had been ranked by retrieved trade statistics.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion", "statement", "evidence_class", "source_reference"],
        "properties": {
          "criterion": {
            "enum": [
              "trade_value_or_volume",
              "data_availability",
              "strategic_trade_relevance",
              "chokepoint_exposure",
              "geographic_coverage",
              "operational_distinctiveness",
              "source_backed_analysis_support"
            ]
          },
          "statement": {"type": "string", "minLength": 1},
          "evidence_class": {"$ref": "observation_common.schema.json#/$defs/evidenceClass"},
          "source_reference": {
            "type": ["string", "null"],
            "description": "Source ID, document path or public URL supporting the statement. Null is permitted only when evidence_class is 'analytical_inference' or 'insufficient_evidence'."
          }
        }
      }
    },
    "data_period_used": {
      "type": ["string", "null"],
      "description": "The data period the selection evidence was drawn from. Null when no dated quantitative evidence was retrieved -- which must then also be stated in known_limitations."
    },
    "known_limitations": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "review_date": {"type": "string", "format": "date"},
    "status": {"enum": ["active", "provisional", "retired"]}
  }
}
